import java.util.Scanner;

public class Main {
    public static void main(String[] args) {
        Scanner s = new Scanner(System.in);

        System.out.print("Enter a number: ");
        int num = s.nextInt();

        int maxDigit = 0;

        while (num > 0) {
            int digit = num % 10;   

            if (digit > maxDigit) {
                maxDigit = digit;
            }

            num = num / 10;  
        }

        System.out.println("Largest digit = " + maxDigit);
    }
}
